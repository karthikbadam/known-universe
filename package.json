{
  "name": "known-universe",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Known Universe: interactive journal of canonical visualizations in physics. Module 01 is Cosmology.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/smoke.mjs",
    "simulate:hubble": "tsx scripts/simulate/hubble1929.ts",
    "simulate:cmb": "tsx scripts/simulate/cmb_powerspectrum.ts",
    "simulate:bbn": "tsx scripts/simulate/bbn.ts",
    "simulate:bao": "tsx scripts/simulate/bao.ts",
    "simulate:gw": "tsx scripts/simulate/gw150914.ts",
    "simulate:pantheon": "tsx scripts/simulate/pantheon.ts",
    "simulate:sparc": "tsx scripts/simulate/sparc.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@uwdata/mosaic-core": "^0.26.0",
    "@uwdata/mosaic-plot": "^0.26.0",
    "@uwdata/mosaic-sql": "^0.26.0",
    "@uwdata/vgplot": "^0.26.0",
    "katex": "^0.16.11",
    "lucide-react": "^1.15.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-katex": "^3.1.0",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@types/react-katex": "^3.0.4",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
